# IBF App — production environment template
# Copy to /opt/ibf_app/.env and fill in real values before starting the service.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////opt/ibf_app/data/ibf.db

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX       # openssl rand -hex 32
CSRF_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX      # openssl rand -hex 32

# ── Ollama LLM ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=ibf-alerts@rimes.int

# ── SMS / WhatsApp (optional) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── App behaviour ─────────────────────────────────────────────────────────────
TRIGGER_COOLDOWN_HOURS=6
SESSION_EXPIRE_HOURS=12
