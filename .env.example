# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./ibf_app.db
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Application ───────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000

# ── SMTP (email notifications) ────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
RESET_TOKEN_EXPIRE_MINUTES=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE=ibf_app.log
LOG_LEVEL=INFO

# ── Alert & notification settings ────────────────────────────────────────────
# Send sync failure email after N consecutive daily sync errors
SMTP_FAILURE_ALERT_AFTER=3
# Suppress duplicate trigger notifications within this window (hours)
TRIGGER_COOLDOWN_HOURS=6
# Re-escalate unacknowledged activations after this many hours
ALERT_ESCALATION_HOURS=24
# Weekly digest schedule: day of week (0=Monday) and hour (UTC)
WEEKLY_DIGEST_DAY=0
WEEKLY_DIGEST_HOUR=8

# ── AI Assistant (Ollama) ─────────────────────────────────────────────────────
# Free, runs locally — no account or API key needed.
# Step 1: install Ollama from https://ollama.com
# Step 2: ollama serve
# Step 3: ollama pull gemma4:e4b   (recommended — strong reasoning, lightweight)
# Alternatives:
#   ollama pull qwen2.5:7b          (strong structured data reasoning — 8 GB RAM)
#   ollama pull gemma3:4b           (lighter — 4 GB RAM)
#   ollama pull phi4                (stronger reasoning — 10 GB RAM)
#   ollama pull llama3.1:8b         (general purpose — 6 GB RAM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
